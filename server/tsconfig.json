{
  "extends": "@packages/tsconfig/tsconfig.base.json",
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "rootDir": ".",
    "types": ["node"],
    "paths": {
      "~db/*": ["./src/db/*"],
      "~sharedTypes/*": ["./src/sharedTypes/*"],
      "~entities/*": ["./src/entities/*"],
      "~src/*": ["./src/*"],
      "~e2e/*": ["./e2e/*"]
    }
  },
  "include": ["src", "scripts", "e2e"]
}
