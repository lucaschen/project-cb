{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "~shared/*": ["./src/*"]
    },
    "outDir": "./dist",
    "rootDir": "./src",
    "target": "ES2020"
  },
  "include": ["src", "./eslint.config.common.ts"]
}
