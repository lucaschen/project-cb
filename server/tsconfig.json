{
  "extends": "@packages/tsconfig/tsconfig.base.json",
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "./src",
    "types": ["node"],
    "paths": {
      "@root/*": ["./src/*"],
      "@db/*": ["./src/db/*"],
      "@sharedTypes/*": ["./src/sharedTypes/*"]
    }
  },
  "include": ["src"]
}
