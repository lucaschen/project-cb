{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false,

    "outDir": "./dist",
    "rootDir": "./src",

    "composite": false
  },
  "include": ["src"],
  "exclude": [
    "**/*.test.*",
    "**/*.spec.*",
    "**/__tests__/**",
    "dist",
    "node_modules"
  ]
}
